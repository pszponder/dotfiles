#!/usr/bin/env bash

set -euo pipefail

echo
echo "🔧 Initial Chezmoi Configuration"
echo "--------------------------------"

git_name="{{ .git_name | default "" }}"
git_email="{{ .git_email | default "" }}"
machine_type="{{ .machine_type | default "" }}"

if [[ -z "$git_name" ]]; then
  read -rp "Git username (full name): " git_name
fi

if [[ -z "$git_email" ]]; then
  read -rp "Git email: " git_email
  git_email=$(echo "$git_email" | tr '[:upper:]' '[:lower:]')
fi

if [[ -z "$machine_type" ]]; then
  echo "Machine type:"
  select type in "workstation" "server"; do
    machine_type="$type"
    break
  done
fi

echo
echo "✅ Configuration summary"
echo "------------------------"
echo "Git username : $git_name"
echo "Git email    : $git_email"
echo "Machine type : $machine_type"
echo

# Persist answers into chezmoi config
chezmoi data set git_name "$git_name"
chezmoi data set git_email "$git_email"
chezmoi data set machine_type "$machine_type"