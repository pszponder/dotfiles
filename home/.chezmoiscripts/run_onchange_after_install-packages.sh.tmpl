#!/usr/bin/env bash
set -euo pipefail

{{- /* --- resolve template variables --- */ -}}
{{- $machineType := .machine_type | default "workstation" -}}
{{- $linuxID := "" -}}
{{- $linuxFamily := "" -}}
{{- if eq .chezmoi.os "linux" -}}
{{-   $linuxID = .chezmoi.osRelease.id -}}
{{-   $linuxFamily = .chezmoi.osRelease.idLike | default .chezmoi.osRelease.id -}}
{{/*   Map immutable Fedora variants (Silverblue, Kinoite, Sway Atomic, etc.) to fedora_atomic */}}
{{-   if and (eq $linuxFamily "fedora") (lookPath "rpm-ostree") -}}
{{-     $linuxID = "fedora_atomic" -}}
{{-   end -}}
{{/*   Fall back to idLike if no packages defined for exact id */}}
{{-   if not (dig "linux" $linuxID $machineType "items" (list) .packages) -}}
{{-     $linuxID = $linuxFamily -}}
{{-   end -}}
{{- end -}}
{{- $packages := dig "linux" $linuxID $machineType "items" (list) .packages -}}
{{- $nerdfonts := dig "items" (list) .nerdfonts -}}
{{- $flatpaks := dig "items" (list) .flatpaks }}

OS="{{ .chezmoi.os }}"
LINUX_ID="{{ $linuxID }}"
LINUX_FAMILY="{{ $linuxFamily }}"
MACHINE_TYPE="{{ $machineType }}"

SCRIPTS_DIR="${HOME}/.local/share/chezmoi/scripts"

command_exists() { command -v "$1" >/dev/null 2>&1; }

packages=({{ range $packages }}{{ . | quote }} {{ end }})
nerdfonts=({{ range $nerdfonts }}{{ . | quote }} {{ end }})
flatpaks=({{ range $flatpaks }}{{ . | quote }} {{ end }})

# ===================================
# Common packages
# ===================================

# Native packages (Linux)
if [[ "$OS" == "linux" ]]; then
  bash "$SCRIPTS_DIR/install_packages_native.sh" "$LINUX_FAMILY" "${packages[@]}"
else
  echo "⏭ Skipping native packages (Linux only)."
fi

# Homebrew packages (via Brewfile)
bash "$SCRIPTS_DIR/install_packages_brew.sh"

# Nerd Fonts
if [[ "${#nerdfonts[@]}" -eq 0 ]]; then
  echo "⚠️ No Nerd Fonts configured, skipping."
else
  nerdfonts_script="$SCRIPTS_DIR/install_nerdfonts-linux.sh"
  if [[ -x "$nerdfonts_script" ]]; then
    echo "🔤 Installing Nerd Fonts..."
    bash "$nerdfonts_script" "${nerdfonts[@]}"
  else
    echo "⚠️ Nerd Fonts setup script not found or not executable, skipping."
  fi
fi

# mise auto-install
bash "$SCRIPTS_DIR/install_packages_mise.sh"

# ===================================
# Workstation-specific packages
# ===================================
{{- if eq $machineType "workstation" }}

# Flatpak apps
bash "$SCRIPTS_DIR/install_packages_flatpak.sh" "${flatpaks[@]}"

# Warp
if command_exists warp-terminal; then
  echo "✅ Warp is already installed, skipping."
else
  warp_script="$SCRIPTS_DIR/setup_warp_terminal.sh"
  if [[ -x "$warp_script" ]]; then
    echo "🚀 Installing Warp..."
    bash "$warp_script"
  else
    echo "⚠️ Warp setup script not found or not executable, skipping."
  fi
fi

# Kitty
if [[ -x "$HOME/.local/kitty.app/bin/kitty" ]]; then
  echo "✅ Kitty is already installed, skipping."
else
  kitty_script="$SCRIPTS_DIR/setup_kitty.sh"
  if [[ -x "$kitty_script" ]]; then
    echo "🐱 Installing Kitty..."
    bash "$kitty_script"
  else
    echo "⚠️ Kitty setup script not found or not executable, skipping."
  fi
fi

{{- end }}

# ===================================
# Server-specific packages
# ===================================
{{- if eq $machineType "server" }}

# Add server-specific package installations here

{{- end }}

echo "✅ Package installation complete."
