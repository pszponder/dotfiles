#!/usr/bin/env bash
set -euo pipefail

########################################
# Load Logging Utilities
########################################
LOG_LIB="${HOME}/.local/lib/utils_logging.sh"

if [[ -f "$LOG_LIB" ]]; then
  # shellcheck source=/dev/null
  source "$LOG_LIB"
else
  echo "❌ Logging library not found at $LOG_LIB" >&2
  exit 1
fi

########################################
# Helper Functions
########################################
confirm() {
  local prompt="${1:-Are you sure?}"
  local default="${2:-N}"

  local suffix
  [[ "$default" == "Y" ]] && suffix="[Y/n]" || suffix="[y/N]"

  while true; do
    # Use logging for the question (no newline issues)
    printf "❓ %s %s: " "$prompt" "$suffix"

    read -r response
    response="${response:-$default}"

    case "$response" in
      [yY][eE][sS]|[yY])
        log_info "User selected: yes"
        return 0
        ;;
      [nN][oO]|[nN])
        log_info "User selected: no"
        return 1
        ;;
      *)
        log_warn "Please answer yes or no."
        ;;
    esac
  done
}

run_if_confirmed() {
  local prompt="$1"
  local default="${2:-N}"
  shift 2  # Remove prompt + default; remaining args are the command and arguments

  # Confirm with the user
  if confirm "$prompt" "$default"; then
    # Validate that the command exists
    if command -v "$1" >/dev/null 2>&1 || [[ -f "$1" ]]; then
      log_info "Running: $*"
      "$@"  # Execute the command with all arguments
    else
      log_error "Command not found: $1"
      return 1
    fi
  else
    log_info "Skipped: $*"
  fi
}

########################################
# Load Minimal environment
########################################
log_info "Setting up temporary PATH for setup..."

export PATH="$HOME/.cargo/bin:$HOME/.mise/bin:$PATH"
hash -r

SCRIPTS_DIR="$(dirname "$CHEZMOI_SOURCE_DIR")/scripts"

########################################
# Switch Git Remote from HTTPS to SSH
########################################
git2ssh -C "$(dirname "$CHEZMOI_SOURCE_DIR")"

########################################
# Core Setup
########################################
# "N" means that if user just presses ENTER, "N" is sent by default
# If you want the command to be accepted by default, either change to "Y" or don't include this second argument
run_if_confirmed "Setup Directories?" "N" "$SCRIPTS_DIR/setup_directories.sh"

setup_ssh_keys() {
  log_info "Setting up SSH keys..."

  run_if_confirmed \
    "Setup SSH config?" "Y" \
    "$SCRIPTS_DIR/setup_ssh_config.sh"

  run_if_confirmed \
    "Generate SSH key?" "Y" \
    sshkeygen
}

run_if_confirmed \
  "Do you want to setup SSH keys?" "N" \
  setup_ssh_keys

