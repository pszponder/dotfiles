#!/usr/bin/env bash

set -e  # Exit immediately on any error

echo "🔧 Running setup tasks after applying dotfiles..."

# Define the location of the scripts in the repo
SCRIPTS_DIR="$(dirname "$CHEZMOI_SOURCE_DIR")/scripts"
{{- if .machine_type }}
MACHINE_TYPE="{{ .machine_type }}"
{{- else }}
read -rp "❓ Is this machine a workstation or server? [workstation/server]: " MACHINE_TYPE
if [[ "$MACHINE_TYPE" != "workstation" && "$MACHINE_TYPE" != "server" ]]; then
  echo "⚠️ Invalid machine type '$MACHINE_TYPE'. Must be 'workstation' or 'server'."
  exit 1
fi
{{- end }}

# Rebuild bat's cache to ensure custom themes are recognized from dotfiles
bat cache --build

# Setup directories
$SCRIPTS_DIR/setup_directories.sh

# Configure Podman storage driver based on filesystem type
$SCRIPTS_DIR/setup_podman_storage.sh

# Run the script to initialize SSH config
$SCRIPTS_DIR/setup_ssh_config.sh

# Setup SSH Keys
read -rp "❓ Do you want to setup SSH Keys? [y/N]: " response
case "$response" in
  [yY][eE][sS]|[yY])
    echo "🔑 Setting up SSH keys..."
    sshkeygen
    ;;
  *)
    echo "❌ Skipping SSH Key generation."
    ;;
esac

# Setup COSMIC desktop keyring (Arch Linux only)
if [[ -f /etc/arch-release ]]; then
  $SCRIPTS_DIR/setup_arch_cosmic-keyring.sh
fi

# Switch chezmoi repo remote from HTTPS to SSH
REPO_DIR="$(dirname "$CHEZMOI_SOURCE_DIR")"
CURRENT_URL=$(git -C "$REPO_DIR" remote get-url origin 2>/dev/null || true)

if [[ "$CURRENT_URL" == https://github.com/* ]]; then
  SSH_URL="${CURRENT_URL/https:\/\/github.com\//git@github.com:}"
  echo "🔄 Switching chezmoi repo remote from HTTPS to SSH..."
  echo "   Old: $CURRENT_URL"
  echo "   New: $SSH_URL"
  git -C "$REPO_DIR" remote set-url origin "$SSH_URL"
  echo "✅ Remote URL switched to SSH."
else
  echo "ℹ️ Remote URL is already SSH or not GitHub, skipping."
fi

# ====================================
# Workstation-only setup
# ====================================
if [[ "$MACHINE_TYPE" == "workstation" ]]; then
  echo "🖥 Running workstation-specific setup..."
  # Add workstation-specific tasks here
fi

# ====================================
# Server-only setup
# ====================================
if [[ "$MACHINE_TYPE" == "server" ]]; then
  echo "🖧 Running server-specific setup..."
  # Add server-specific tasks here
fi
