# Directory navigation
alias ..='cd ..'
alias ...='cd ../..'
alias ..2='cd ../..'
alias ....='cd ../../..'
alias ..3='cd ../../..'
alias .....='cd ../../../..'
alias ..4='cd ../../../..'
alias ..5='cd ../../../../..'
alias ..6='cd ../../../../../..'

# File System Navigation (via lsd)
alias l='lsd -l'
alias ls='lsd -l'
alias la='lsd -a'
alias ll='lsd -la'
alias lla='lsd -la'
alias lt='lsd --tree'
