[data]
# Prompt for machine type on first apply
{{- if hasKey . "machine_type" }}
    machine_type = "{{ .machine_type }}"
{{- else }}
    machine_type = "{{ promptChoice "Machine type (server/workstation)" (list "server" "workstation") }}"
{{- end }}
    git_name = {{ promptStringOnce . "git_name" "Git username" | quote }}
    git_email = {{ promptStringOnce . "git_email" "Git email" | quote }}
