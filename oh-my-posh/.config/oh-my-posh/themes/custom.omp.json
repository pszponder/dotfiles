{
	"$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
	"version": 2,
	"console_title_template": "{{.Folder}}",
	"palette": {
		"rosewater": "#f5e0dc",
		"flamingo": "#f2cdcd",
		"pink": "#f5c2e7",
		"mauve": "#cba6f7",
		"red": "#f38ba8",
		"maroon": "#eba0ac",
		"peach": "#fab387",
		"yellow": "#f9e2af",
		"green": "#a6e3a1",
		"teal": "#94e2d5",
		"sky": "#89dceb",
		"sapphire": "#74c7ec",
		"blue": "#89B4FA",
		"lavender": "#B4BEFE",
		"text": "#cdd6f4",
		"subtext1": "#bac2de",
		"subtext0": "#a6adc8",
		"overlay2": "#9399b2",
		"overlay1": "#7f849c",
		"overlay0": "#6c7086",
		"surface2": "#585b70",
		"surface1": "#45475a",
		"surface0": "#313244",
		"base": "#1e1e2e",
		"mantle": "#181825",
		"crust": "#11111b",
		"white": "p:text",
		"black": "p:base",
		"os": "#ACB0BE",
		"closer": "p:os",
		"git-foreground": "p:base",
		"git": "p:yellow",
		"git-modified": "p:peach",
		"git-diverged": "p:red",
		"git-ahead": "p:mauve",
		"git-behind": "p:mauve"
	},
	"blocks": [
		{
			"type": "prompt",
			"alignment": "left",
			"segments": [
				{
					"type": "path",
					"style": "plain",
					"foreground": "p:blue",
					"properties": {
						"folder_icon": "\ue5fe",
						"home_icon": "<b>~</b>",
						"style": "agnoster_full",
						"max_width": 80,
						"max_depth": 3
					},
					"template": "\n{{ .Path }} "
				}
			]
		},
		{
			"type": "prompt",
			"alignment": "right",
			"segments": [
				{
					"type": "executiontime",
					"style": "plain",
					"foreground": "p:lavender",
					"template": " <#fefefe></> {{ .FormattedMs }} ",
					"properties": {
						"threshold": 500,
						"style": "austin",
						"always_enabled": true
					}
				},
				{
					"type": "deno",
					"style": "plain",
					"foreground": "#3C82F6",
					"template": "  {{ .Full }} "
				},
				{
					"type": "docker",
					"style": "plain",
					"foreground": "#0B59E7",
					"template": "  {{ .Context }} "
				},
				{
					"type": "dotnet",
					"style": "plain",
					"foreground": "#00ffff",
					"template": "  {{ .Full }} "
				},
				{
					"type": "elixir",
					"style": "plain",
					"foreground": "#422251",
					"template": "  {{ .Full }} "
				},
				{
					"type": "go",
					"style": "plain",
					"foreground": "#7FD5EA",
					"template": "  {{ .Full }} "
				},
				{
					"type": "lua",
					"style": "plain",
					"foreground": "p:blue",
					"template": "  {{ .Full }} "
				},
				{
					"type": "node",
					"style": "plain",
					"foreground": "#6CA35E",
					"template": "  {{ .Full }} "
				},
				{
					"type": "python",
					"style": "plain",
					"foreground": "p:green",
					"template": "{{ if .Error }}  {{ .Error }}{{ else }}{{ if .Venv }}(venv){{ end }}  {{ .Full }}{{ end }}",
					"properties": {
						"display_mode": "context"
					}
				},
				{
					"type": "react",
					"style": "plain",
					"foreground": "#81a1c1",
					"template": "  {{ .Full }} "
				},
				{
					"type": "ruby",
					"style": "plain",
					"foreground": "#4063D8",
					"template": "  {{ .Full }}"
				},
				{
					"type": "rust",
					"style": "plain",
					"foreground": "#99908a",
					"template": "  {{ .Full }} "
				},
				{
					"type": "terraform",
					"style": "plain",
					"foreground": "#ebcc34",
					"template": "{{.WorkspaceName}}"
				},
				{
					"type": "unity",
					"style": "plain",
					"foreground": "p:black",
					"properties": {
						"http_timeout": 2000
					}
				}
			]
		},
		{
			"type": "prompt",
			"alignment": "left",
			"newline": true,
			"segments": [
				{
					"type": "git",
					"style": "plain",
					"foreground": "p:lavender",
					"template": "{{ .HEAD }}{{if .BranchStatus }} {{ .BranchStatus }}{{ end }}{{ if .Working.Changed }} \uf044 {{ .Working.String }}{{ end }}{{ if and (.Working.Changed) (.Staging.Changed) }} |{{ end }}{{ if .Staging.Changed }} \uf046 {{ .Staging.String }}{{ end }} ",
					"properties": {
						"fetch_status": true,
						"fetch_upstream_icon": true,
						"branch_icon": "\ue725 ",
						"cherry_pick_icon": "\ue29b ",
						"commit_icon": "\uf417 ",
						"merge_icon": "\ue727 ",
						"no_commits_icon": "\uf0c3 ",
						"rebase_icon": "\ue728 ",
						"revert_icon": "\uf0e2 ",
						"tag_icon": "\uf412 "
					}
				},
				{
					"type": "status",
					"style": "plain",
					"foreground": "p:green",
					"foreground_templates": [
						"{{ if .Error }}#f38ba8{{ end }}"
					],
					"template": "<b>{{ if .Error }}❌{{ else }}❯{{ end }}</b> ",
					"properties": {
						"always_enabled": true
					}
				}
			]
		}
	],
	"transient_prompt": {
		"background": "transparent",
		"foreground": "p:white",
		"template": "❯ "
	}
}