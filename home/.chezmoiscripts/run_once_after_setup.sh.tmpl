      log_info "Setting up full Linux server..."
      case "$LINUX_DISTRO" in
        ubuntu)
          # TODO: Run scripts for Ubuntu Server
          ;;
        fedora)
          # TODO: Run scripts for Fedora Server
          ;;
        fedora-silverblue)
          # TODO: Run scripts for Fedora Silverblue Server
          ;;
        arch)
          # TODO: Run scripts for Arch Server
          ;;
