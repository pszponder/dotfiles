{{- if eq (.machine_type | default "workstation") "workstation" -}}
#!/usr/bin/env bash
set -euo pipefail

{{- /* --- resolve template variables --- */ -}}
{{- $flatpaks := dig "items" (list) .flatpaks }}

OS="{{ .chezmoi.os }}"

command_exists() { command -v "$1" >/dev/null 2>&1; }

# ===================================
# Flatpak apps
# ===================================
flatpaks=({{ range $flatpaks }}{{ . | quote }} {{ end }})

if [[ "$OS" != "linux" ]]; then
  echo "⏭ Skipping Flatpak apps (Linux only)."
elif ! command_exists flatpak; then
  echo "⚠️ Flatpak is not installed, skipping Flatpak apps."
elif [[ "${#flatpaks[@]}" -eq 0 ]]; then
  echo "⚠️ No Flatpak apps configured, skipping."
else
  echo "📦 Installing Flatpak apps..."
  flatpak remote-add --if-not-exists flathub https://dl.flathub.org/repo/flathub.flatpakrepo
  for app in "${flatpaks[@]}"; do
    echo "  → $app"
    flatpak install --noninteractive flathub "$app" || echo "⚠️ Failed to install $app"
  done
fi

# ===================================
# Terminal installs
# ===================================

# Warp
if command_exists warp-terminal; then
  echo "✅ Warp is already installed, skipping."
else
  warp_script="${HOME}/.local/share/chezmoi/scripts/setup_warp_terminal.sh"
  if [[ -x "$warp_script" ]]; then
    echo "🚀 Installing Warp..."
    bash "$warp_script"
  else
    echo "⚠️ Warp setup script not found or not executable, skipping."
  fi
fi

# Kitty
if [[ -x "$HOME/.local/kitty.app/bin/kitty" ]]; then
  echo "✅ Kitty is already installed, skipping."
else
  kitty_script="${HOME}/.local/share/chezmoi/scripts/setup_kitty.sh"
  if [[ -x "$kitty_script" ]]; then
    echo "🐱 Installing Kitty..."
    bash "$kitty_script"
  else
    echo "⚠️ Kitty setup script not found or not executable, skipping."
  fi
fi

echo "✅ Workstation package installation complete."
{{- end }}
